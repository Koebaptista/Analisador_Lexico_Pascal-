digraph AFD {
    rankdir=LR;
    node [shape=circle];

    start [shape=point];
    start -> q0;

    // IDENTIFICADOR
    q0 -> q1 [label="letra"];
    q1 -> q1 [label="letra|digito"];

    // NUMEROS
    q0 -> q2 [label="digito"];
    q2 -> q2 [label="digito"];
    q2 -> q3 [label="."];
    q3 -> q4 [label="digito"];
    q4 -> q4 [label="digito"];

    // OPERADORES RELACIONAIS
    q0 -> q5 [label="<"];
    q5 -> q6 [label="="];   // <=
    q5 -> q7 [label=">"];   // <>
    
    q0 -> q8 [label=">"];
    q8 -> q9 [label="="];   // >=

    // ATRIBUIÇÃO
    q0 -> q10 [label=":"];
    q10 -> q11 [label="="]; // :=

    // IGUAL
    q0 -> q12 [label="="];

    // COMENTARIO
    q0 -> q13 [label="{"];
    q13 -> q13 [label="qualquer"];
    q13 -> q14 [label="}"];

    // FINAIS
    node [shape=doublecircle];
    q1 q2 q4 q5 q6 q7 q8 q9 q11 q12;
}