digraph NUM {
    rankdir=LR;

    start [shape=point];
    start -> q0;

    q0 -> q1 [label="dígito"];
    q1 -> q1 [label="dígito"];

    q1 -> q2 [label="."];
    q2 -> q3 [label="dígito"];
    q3 -> q3 [label="dígito"];

    q1 [shape=doublecircle, label="NUM_INT"];
    q3 [shape=doublecircle, label="NUM_REAL"];

    q2 -> erro [label="outro"];
    erro [color=red];
}